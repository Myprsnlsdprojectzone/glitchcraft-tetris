# ── Google Analytics 4 ──────────────────────────────────────────────────
# Get your Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
VITE_GA_ID=G-XXXXXXXXXX

# ── Google AdSense ───────────────────────────────────────────────────────
# Get your Publisher ID from: https://adsense.google.com/
# Format: ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# ── Supabase (Global Leaderboard) ───────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
# Leave empty to disable global leaderboard (local-only mode still works)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
